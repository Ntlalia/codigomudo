package org.example;

public class Main {

    public static double calcularImpuesto(double salario, double tasa, String region) {
        double deduccion = tasa * 0.15;

        if (region.equals("SV")) {
            return (salario - deduccion) + 13;
        } else {
            double resultado = salario - deduccion;
            return resultado;
        }
    }

    public static void main(String[] args) {
        double resultado = calcularImpuesto(100, 10, "SV");
        System.out.println(resultado); // 111.5
    }
}
